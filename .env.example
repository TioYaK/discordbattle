# Token do seu bot Discord (obtenha em https://discord.com/developers/applications)
BOT_TOKEN=seu_token_aqui

# Chave para criptografar telefones no banco (64 caracteres hex = 32 bytes)
# Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
PHONE_ENCRYPTION_KEY=

# Caminho opcional do Chrome (usado pelo scraper e WhatsApp)
# CHROME_PATH=C:\Program Files\Google\Chrome\Application\chrome.exe

# URL do backend do BattleStorm (para alimentar dados de highscore)
# Deixe vazio para desabilitar o sync
BATTLESTORM_API_URL=https://seu-backend.railway.app/api
